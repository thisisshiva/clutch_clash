PORT=3000
# Supabase (optional - only needed for JWT verification; guest mode works without it)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Gemini (optional - generates draft titles/descriptions for theater video publishing;
# falls back to templated copy when unset)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
